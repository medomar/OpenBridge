{
  "connectors": [
    {
      "type": "whatsapp",
      "enabled": true,
      "options": {
        "sessionName": "openbridge-default",
        "sessionPath": ".wwebjs_auth"
      }
    }
  ],
  "providers": [
    {
      "type": "claude-code",
      "enabled": true,
      "options": {
        "workspacePath": "~/projects/my-project",
        "maxTokens": 4096
      }
    }
  ],
  "defaultProvider": "claude-code",
  "auth": {
    "whitelist": ["+1234567890"],
    "prefix": "/ai",
    "rateLimit": {
      "enabled": true,
      "maxMessages": 10,
      "windowMs": 60000
    }
  },
  "logLevel": "info"
}
