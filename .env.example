# OpenBridge Environment Configuration
# Copy this file to .env and fill in your values

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Config file path (default: config.json in project root)
CONFIG_PATH=./config.json

# WhatsApp connector options
# WHATSAPP_SESSION_NAME=openbridge-default

# Claude Code provider options
# CLAUDE_CODE_WORKSPACE=~/projects/my-project
