# OpenBridge Environment Configuration
# Copy this file to .env and fill in your values

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Config file path (default: config.json in project root)
CONFIG_PATH=./config.json

# WhatsApp connector options
# WHATSAPP_SESSION_NAME=openbridge-default

# Claude Code provider options
# CLAUDE_CODE_WORKSPACE=~/projects/my-project

# OpenAI API key — optional, shared with Codex
# Used for two features:
#   1. Voice message transcription via OpenAI Whisper API ($0.006/min, zero local setup)
#   2. Codex AI provider (if you use Codex as your AI tool instead of Claude Code)
# If unset, voice transcription falls back to local whisper CLI, then a placeholder message.
# OPENAI_API_KEY=sk-...
