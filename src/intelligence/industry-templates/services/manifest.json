          "field_type": "date",
          "required": true,
          "searchable": true,
          "sort_order": 0
        },
        {
          "name": "project_id",
          "label": "Project",
          "field_type": "link",
          "required": true,
          "sort_order": 1,
          "link_doctype": "project"
        },
        {
          "name": "client_id",
          "label": "Client",
          "field_type": "link",
          "sort_order": 2,
          "link_doctype": "client"
        },
        {
          "name": "task",
          "label": "Task / Description",
          "field_type": "text",
          "required": true,
          "searchable": true,
          "sort_order": 3
        },
        {
          "name": "hours",
          "label": "Hours",
          "field_type": "number",
          "required": true,
          "sort_order": 4
        },
        {
          "name": "hourly_rate",
          "label": "Hourly Rate",
          "field_type": "currency",
          "sort_order": 5
        },
        {
          "name": "amount",
