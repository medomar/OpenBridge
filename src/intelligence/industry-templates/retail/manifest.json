          "color": "purple",
          "sort_order": 2
        },
        { "name": "in_transit", "label": "In Transit", "color": "orange", "sort_order": 3 },
        { "name": "received", "label": "Received", "color": "green", "sort_order": 4 },
        {
          "name": "cancelled",
          "label": "Cancelled",
          "color": "red",
          "is_terminal": true,
          "sort_order": 5
        }
      ],
