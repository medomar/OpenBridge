        { "name": "city", "label": "City", "field_type": "text", "sort_order": 8 },
        {
          "name": "date_of_birth",
          "label": "Date of Birth",
          "field_type": "date",
          "sort_order": 9
        },
        {
          "name": "preferred_categories",
