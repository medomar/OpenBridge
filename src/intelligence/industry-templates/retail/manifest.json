        },
        {
          "from_state": "draft",
          "to_state": "cancelled",
          "action_name": "cancel",
          "action_label": "Cancel Order"
        },
        {
          "from_state": "sent",
          "to_state": "confirmed",
          "action_name": "confirm",
          "action_label": "Mark Confirmed"
        },
        {
          "from_state": "sent",
          "to_state": "cancelled",
          "action_name": "cancel",
          "action_label": "Cancel Order"
        },
        {
          "from_state": "confirmed",
          "to_state": "in_transit",
          "action_name": "ship",
          "action_label": "Mark Shipped"
        },
        {
          "from_state": "in_transit",
          "to_state": "received",
          "action_name": "receive",
          "action_label": "Mark Received"
        }
